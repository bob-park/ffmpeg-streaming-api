# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
LOG_FFMPEG_STDERR_LEVEL=info
LOG_FFMPEG_PROGRESS_LEVEL=debug
LOG_FFMPEG_PROGRESS_EVERY=1

# Database
DATABASE_URL=postgresql://transcoder:transcoder@localhost:5432/transcoder
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# Storage
STORAGE_DIR=/var/lib/transcoder
PIDFILE_SUBDIR=.pids

# Concurrency
MAX_CONCURRENCY=6
MAX_QUEUE_DEPTH=50

# Job lifecycle (seconds)
DEFAULT_TTL_SECONDS=300
MAX_RUN_SECONDS=21600
GRACE_JANITOR_SECONDS=60
LAST_ACCESS_DEBOUNCE_SECONDS=30

# Shutdown
SHUTDOWN_GRACE_SECONDS=15

# Janitor
JANITOR_INTERVAL_SECONDS=30

# FFmpeg / HLS
HLS_SEGMENT_SECONDS=4
HLS_LIVE_LIST_SIZE=6
X264_PRESET=veryfast
X264_PROFILE=main
AUDIO_BITRATE=128k
AUDIO_CHANNELS=2
AUDIO_SAMPLE_RATE=48000

# Security
CORS_ALLOW_ORIGINS=["*"]
URL_DENY_HOSTNAMES=["localhost","metadata","metadata.google.internal"]
URL_ALLOW_SCHEMES=["http","https"]
# LAN/개발용: 사설 IP 대역(10/8, 172.16/12, 192.168/16) 허용. 기본 false.
# 이걸 true로 해도 loopback/link-local/multicast/reserved 는 여전히 차단됨.
URL_ALLOW_PRIVATE_IPS=false

# SSE
SSE_PING_INTERVAL_SECONDS=15
